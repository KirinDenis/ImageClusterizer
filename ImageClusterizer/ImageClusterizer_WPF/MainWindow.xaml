<Window
    x:Class="ImageClusterizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ImageClusterizer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ImageClusterizer.Models"
    
    mc:Ignorable="d"
    Title="AI :: Image Clusterizer"
    Width="1200" Height="800"
    WindowStartupLocation="CenterScreen">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <ToolBar Grid.Row="0" Height="48">
            <Button
                ToolTip="Select images"
                Command="{Binding ViewModel.StartScanImagesCommand}">
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📂" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Select location to scan images" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button
                ToolTip="Stop scanning"
                Command="{Binding ViewModel.CancelScanCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏹" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Stop scanning" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button
                ToolTip="Reload existing from database"
                Command="{Binding ViewModel.LoadExistingClustersCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Reload exists from database" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </ToolBar>


        <StackPanel Grid.Row="1" Margin="20,10" 
                    Visibility="{Binding ViewModel.ProgressVisibility, Mode=OneWay}">
            <TextBlock Margin="0,0,0,4">
                <Run Text="Processing: "/>
                <Run Text="{Binding ViewModel.CurrentFile, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar
                Value="{Binding ViewModel.Progress, Mode=OneWay}"
                Maximum="100"
                Height="8"
                Margin="0,0,0,4"/>
            <TextBlock>
                <Run Text="{Binding ViewModel.ProcessedCountText, Mode=OneWay}"/>
                <Run Text=" / "/>
                <Run Text="{Binding ViewModel.TotalCountText, Mode=OneWay}"/>
                <Run Text=" images processed"/>
            </TextBlock>
        </StackPanel>


        <TabControl Grid.Row="2">


            <TabItem Header="Stochastic">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <Canvas
                        Width="{Binding ViewModel.CanvasWidth}"
                        Height="{Binding ViewModel.CanvasHeight}">


                        <ItemsControl ItemsSource="{Binding ViewModel.ImageItems, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>

                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">

                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ImageVisualItem}">
                                    <Border Width="20" Height="20"
                                            CornerRadius="10"
                                            BorderBrush="Gray"
                                            BorderThickness="1"
                                            ToolTipService.ShowDuration="10000">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ThumbnailPath}"
                                                        Stretch="UniformToFill"/>
                                        </Border.Background>
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <Image Source="{Binding ThumbnailPath}"
                                                           Width="150" Height="150"
                                                           Stretch="Uniform"
                                                           Margin="4"/>
                                                    <TextBlock Text="{Binding FilePath}"
                                                               MaxWidth="200"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>


                        <ItemsControl ItemsSource="{Binding ViewModel.ClusterItems, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ClusterVisualItem}">
                                    <Grid Width="60" Height="60">
                                        <Ellipse
                                            Fill="#A07ACCAA"
                                            Stroke="#A07ACCAA"
                                            StrokeThickness="2"/>
                                        <TextBlock
                                            Text="{Binding ClusterId}"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                        <Grid.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{Binding Label}"/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Canvas>
                </ScrollViewer>
            </TabItem>


            <TabItem Header="Clusters">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl
                        ItemsSource="{Binding ViewModel.Clusters, Mode=OneWay}"
                        Margin="20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ImageCluster}">
                                <Border
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="300"
                                    Margin="8"
                                    VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock
                                            Text="{Binding ClusterId}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Margin="0,0,0,4"/>
                                        <TextBlock
                                            Text="{Binding Images.Count}"
                                            Margin="0,0,0,8"/>

                                        <ItemsControl
                                            ItemsSource="{Binding Images}"
                                            MaxHeight="200">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:ImageVector}">
                                                    <Image
                                                        Source="{Binding FilePath}"
                                                        Width="80"
                                                        Height="80"
                                                        Stretch="UniformToFill"
                                                        Margin="2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
