<Window x:Class="ImageClusterizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageClusterizer"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ImageClusterizer.Models"
        mc:Ignorable="d"
        Title="AI :: Image Clusterizer"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: scan controls, vector type selection, clear data -->
        <ToolBar Grid.Row="0" Height="48">

            <Button ToolTip="Select folder and scan images"
                    Command="{Binding ViewModel.StartScanImagesCommand}"
                    IsEnabled="{Binding ViewModel.IsNotScanning}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4C2;" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Select location to scan images" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button ToolTip="Stop scanning"
                    Command="{Binding ViewModel.CancelScanCommand}"
                    IsEnabled="{Binding ViewModel.IsScanning}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x23F9;" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Stop scanning" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button ToolTip="Reload existing vectors from database"
                    Command="{Binding ViewModel.LoadExistingClustersCommand}"
                    IsEnabled="{Binding ViewModel.IsNotScanning}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F504;" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Reload from database" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator/>

            <!-- Vector type selection -->
            <TextBlock Text="Vector type:" VerticalAlignment="Center" Margin="8,0,4,0"/>
            <ComboBox Width="130"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding ViewModel.AvailableVectorTypes}"
                      SelectedItem="{Binding ViewModel.SelectedVectorType, Mode=TwoWay}"
                      IsEnabled="{Binding ViewModel.IsNotScanning}"
                      ToolTip="Embedding (2048D) - better for similarity. Logit (1000D) - classification output."/>

            <Separator/>

            <!-- Clear all data button -->
            <Button ToolTip="Delete all stored vectors, thumbnails and cached data (original files are NOT affected)"
                    Command="{Binding ViewModel.ClearAllDataCommand}"
                    IsEnabled="{Binding ViewModel.IsNotScanning}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F5D1;" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Clear all data" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </ToolBar>

        <!-- Scan progress panel -->
        <StackPanel Grid.Row="1" Margin="20,10"
                    Visibility="{Binding ViewModel.ProgressVisibility, Mode=OneWay}">
            <TextBlock Margin="0,0,0,4">
                <Run Text="Processing: "/>
                <Run Text="{Binding ViewModel.CurrentFile, Mode=OneWay}"/>
            </TextBlock>
            <ProgressBar Value="{Binding ViewModel.Progress, Mode=OneWay}"
                         Maximum="100" Height="8" Margin="0,0,0,4"/>
            <TextBlock>
                <Run Text="{Binding ViewModel.ProcessedCountText, Mode=OneWay}"/>
                <Run Text=" / "/>
                <Run Text="{Binding ViewModel.TotalCountText, Mode=OneWay}"/>
                <Run Text=" images processed"/>
            </TextBlock>
        </StackPanel>

        <!-- Main content tabs -->
        <TabControl Grid.Row="2">

            <!-- PCA scatter view (primary) -->
            <TabItem Header="Map">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Canvas Width="{Binding ViewModel.CanvasWidth}" Height="{Binding ViewModel.CanvasHeight}">

                        <!-- Image dots -->
                        <ItemsControl ItemsSource="{Binding ViewModel.ImageItems, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ImageVisualItem}">
                                    <Border Width="20" Height="20" CornerRadius="10"
                                            BorderBrush="Gray" BorderThickness="1"
                                            ToolTipService.ShowDuration="10000">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                        <Border.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <Image Source="{Binding ThumbnailPath}"
                                                           Width="150" Height="150"
                                                           Stretch="Uniform" Margin="4"/>
                                                    <TextBlock Text="{Binding FilePath}"
                                                               MaxWidth="200" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Border.ToolTip>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Cluster centroids -->
                        <ItemsControl ItemsSource="{Binding ViewModel.ClusterItems, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ClusterVisualItem}">
                                    <Grid Width="60" Height="60">
                                        <Ellipse Fill="#A07ACCAA" Stroke="#A07ACCAA" StrokeThickness="2"/>
                                        <TextBlock Text="{Binding ClusterId}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Grid.ToolTip>
                                            <ToolTip>
                                                <TextBlock Text="{Binding Label}"/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Canvas>
                </ScrollViewer>
            </TabItem>

            <!-- Cosine similarity cluster grid view (secondary) -->
            <TabItem Header="Clusters">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ViewModel.Clusters, Mode=OneWay}" Margin="20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ImageCluster}">
                                <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                        CornerRadius="8" Padding="12"
                                        Width="300" Margin="8" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ClusterId}"
                                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Images.Count}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Images}" MaxHeight="200">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:ImageVector}">
                                                    <Image Source="{Binding ThumbnailPath}"
                                                           Width="80" Height="80"
                                                           Stretch="UniformToFill" Margin="2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
